PERMIT_NUMBER_RE = re.compile(r"\b[A-Z]{1,3}\d{2}-\d{4,6}(?:\.\d{3})?\b", re.I)
DATE_RE = re.compile(r"\b\d{1,2}/\d{1,2}/\d{4}\b")
MONEY_RE = re.compile(r"\$\s*([\d,]+(?:\.\d{2})?)")


