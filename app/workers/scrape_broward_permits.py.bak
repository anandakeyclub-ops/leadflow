"""
Broward permit scraper/importer for Accela Citizen Access permit portals.

Purpose:
- Scrape Broward city Accela permit portals by date range.
- Clean Accela menu/junk rows.
- Recover addresses from row/detail text.
- Avoid putting disclaimer text into owner_name.
- Insert usable records into raw_permits + normalized_permits.

Run examples:
    python -m app.workers.scrape_broward_permits --days-back 7 --visible --limit 25
    python -m app.workers.scrape_broward_permits --source weston_accela --days-back 7 --limit 100

Validate:
    SELECT COUNT(*) FROM normalized_permits WHERE county_id = 4;
    SELECT permit_number, owner_name, business_name, address_1, project_description, issued_date
    FROM normalized_permits WHERE county_id = 4 ORDER BY id DESC LIMIT 25;
"""

from __future__ import annotations

import argparse
import json
import re
import time
from dataclasses import dataclass
from datetime import date, datetime, timedelta
from pathlib import Path
from typing import Dict, Iterable, List, Optional, Tuple
from urllib.parse import urljoin

from bs4 import BeautifulSoup
from selenium import webdriver
from selenium.common.exceptions import NoSuchElementException, WebDriverException
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import Select
from webdriver_manager.chrome import ChromeDriverManager

from app.core.db import get_connection
from app.services.normalize import normalize_name, normalize_address, make_hash

BASE_DIR = Path(__file__).resolve().parents[2]
CONFIG_PATH = BASE_DIR / "config" / "counties" / "broward_permit_sources.json"
DEBUG_DIR = BASE_DIR / "data" / "debug" / "broward_permits"
RAW_DIR = BASE_DIR / "data" / "raw" / "broward" / "permits"

COUNTY_NAME = "Broward"
STATE = "FL"
DATE_FORMATS = ["%m/%d/%Y", "%Y-%m-%d", "%m/%d/%y"]

PERMIT_NUMBER_RE = re.compile(r"^[A-Z]{1,5}\d{2,4}-\d{3,7}(?:\.\d+)?$", re.I)
DATE_RE = re.compile(r"\b\d{1,2}/\d{1,2}/\d{2,4}\b")

JUNK_TEXT = [
    "search cases", "pay fine", "fees", "inspection", "certificate of use",
    "vacation rental", "code enforcement", "planning, zoning", "local business tax",
    "enter information below to search", "search by record information",
    "search by licensed professional information", "landscaping permit fee",
    "engineering permit fee", "building permit fee",
]

OWNER_GARBAGE = [
    "please indicate if you are the current owner",
    "license exemption restrictions",
    "florida contractor licensing law",
    "fs 489",
]

STREET_WORDS = r"(?:ST|STREET|AVE|AVENUE|RD|ROAD|BLVD|BOULEVARD|DR|DRIVE|LN|LANE|CT|COURT|TER|TERRACE|WAY|PL|PLACE|CIR|CIRCLE|PKWY|PARKWAY|TRL|TRAIL)"
ADDRESS_RE = re.compile(
    rf"\b\d{{1,6}}\s+[A-Z0-9 .#/-]+?\s+{STREET_WORDS}\b(?:[, ]+[^|\n]*)?\bFL\b\s*\d{{5}}(?:-?\d{{4}})?",
    re.I,
)

@dataclass
class PermitRecord:
    source_name: str
    jurisdiction: str
    permit_number: str
    permit_type: Optional[str] = None
    project_description: Optional[str] = None
    address_1: Optional[str] = None
    owner_name: Optional[str] = None
    business_name: Optional[str] = None
    issued_date: Optional[date] = None
    trade: Optional[str] = None
    status: Optional[str] = None
    raw_url: Optional[str] = None
    raw_payload: Optional[Dict] = None


def clean_text(value: Optional[str], max_len: Optional[int] = None) -> Optional[str]:
    if value is None:
        return None
    value = re.sub(r"\s+", " ", str(value)).strip(" |:\t\n\r")
    if not value:
        return None
    return value[:max_len] if max_len else value


def parse_date(value: Optional[str]) -> Optional[date]:
    value = clean_text(value)
    if not value:
        return None
    m = DATE_RE.search(value)
    if m:
        value = m.group(0)
    for fmt in DATE_FORMATS:
        try:
            return datetime.strptime(value[:10], fmt).date()
        except ValueError:
            pass
    return None


def is_valid_permit_number(value: Optional[str]) -> bool:
    value = clean_text(value) or ""
    return bool(PERMIT_NUMBER_RE.match(value))


def is_junk_text(value: Optional[str]) -> bool:
    t = (value or "").lower()
    return any(j in t for j in JUNK_TEXT)


def extract_address_from_text(*values: Optional[str]) -> Optional[str]:
    joined = " | ".join([v for v in values if v])
    if not joined:
        return None
    m = ADDRESS_RE.search(joined)
    if m:
        return clean_text(m.group(0).replace(",", " "))
    for part in joined.split("|"):
        p = clean_text(part)
        if not p:
            continue
        if " FL " in f" {p.upper()} " and re.search(r"\d", p) and re.search(STREET_WORDS, p, re.I):
            return clean_text(p.replace(",", " "))
    return None


def clean_owner(value: Optional[str]) -> Optional[str]:
    v = clean_text(value)
    if not v:
        return None
    lower = v.lower()
    if any(g in lower for g in OWNER_GARBAGE):
        return None
    if is_junk_text(v):
        return None
    if any(k in lower for k in [" phone ", " email ", " roofing", " plumbing", " hvac", " electric"]):
        return None
    return v


def extract_contractor(value: Optional[str]) -> Optional[str]:
    v = clean_text(value)
    if not v:
        return None
    lower = v.lower()
    if any(g in lower for g in OWNER_GARBAGE):
        return None
    contractor_keys = ["roofing", "plumbing", "electric", "hvac", "mechanical", "contractor", "corp", "inc", "llc", "phone", "email"]
    if any(k in lower for k in contractor_keys):
        v = re.split(r"\bphone\b|\bwork phone\b|\bemail\b", v, flags=re.I)[0]
        return clean_text(v, 180)
    return None


def clean_description(value: Optional[str], permit_type: Optional[str] = None) -> Optional[str]:
    v = clean_text(value)
    if not v:
        return clean_text(permit_type, 250)
    if is_junk_text(v):
        return None
    parts = [clean_text(p) for p in v.split("|")]
    parts = [p for p in parts if p and not is_junk_text(p)]
    if parts:
        for p in reversed(parts):
            if len(p) > 12 and not DATE_RE.fullmatch(p or "") and not is_valid_permit_number(p):
                if not extract_address_from_text(p):
                    return clean_text(p, 500)
        return clean_text(parts[-1], 500)
    return clean_text(v, 500)


def normalize_record(rec: PermitRecord) -> Optional[PermitRecord]:
    if not is_valid_permit_number(rec.permit_number):
        return None
    payload_text = json.dumps(rec.raw_payload or {}, default=str)
    combined = " | ".join([
        rec.permit_number or "", rec.permit_type or "", rec.project_description or "",
        rec.address_1 or "", rec.owner_name or "", rec.business_name or "", payload_text,
    ])
    contractor = extract_contractor(rec.business_name) or extract_contractor(rec.owner_name) or extract_contractor(combined)
    owner = clean_owner(rec.owner_name)
    address = extract_address_from_text(rec.address_1, rec.project_description, payload_text)
    permit_type = clean_text(rec.permit_type, 120)
    description = clean_description(rec.project_description, permit_type)
    rec.owner_name = owner
    rec.business_name = contractor
    rec.address_1 = address
    rec.permit_type = permit_type
    rec.project_description = description
    rec.trade = infer_trade(" | ".join([permit_type or "", description or "", contractor or ""]))
    return rec


def load_sources() -> List[Dict]:
    if not CONFIG_PATH.exists():
        raise FileNotFoundError(f"Missing config: {CONFIG_PATH}")
    return json.loads(CONFIG_PATH.read_text(encoding="utf-8")).get("sources", [])


def make_driver(visible: bool = False) -> webdriver.Chrome:
    options = Options()
    if not visible:
        options.add_argument("--headless=new")
    options.add_argument("--disable-gpu")
    options.add_argument("--window-size=1600,1200")
    options.add_argument("--no-sandbox")
    options.add_argument("--disable-dev-shm-usage")
    options.add_argument("--disable-blink-features=AutomationControlled")
    options.add_experimental_option("excludeSwitches", ["enable-automation"])
    options.add_experimental_option("useAutomationExtension", False)
    service = Service(ChromeDriverManager().install())
    return webdriver.Chrome(service=service, options=options)


def find_first(driver, selectors: Iterable[Tuple[str, str]]):
    last_error = None
    for by, value in selectors:
        try:
            return driver.find_element(by, value)
        except Exception as exc:
            last_error = exc
    raise NoSuchElementException(str(last_error))


def set_input_value(driver, element, value: str) -> None:
    driver.execute_script("arguments[0].scrollIntoView({block:'center'});", element)
    try:
        element.clear()
        element.send_keys(value)
    except WebDriverException:
        driver.execute_script("arguments[0].value = arguments[1];", element, value)


def try_accept_disclaimer(driver) -> None:
    candidates = [
        (By.ID, "ctl00_PlaceHolderMain_btnContinue"),
        (By.ID, "ctl00_PlaceHolderMain_btnAccept"),
        (By.XPATH, "//input[contains(@value,'Accept') or contains(@value,'Continue') or contains(@value,'I Agree') or contains(@value,'Agree')]") ,
        (By.XPATH, "//button[contains(.,'Accept') or contains(.,'Continue') or contains(.,'I Agree') or contains(.,'Agree')]") ,
    ]
    for _ in range(3):
        clicked = False
        for by, selector in candidates:
            try:
                btn = driver.find_element(by, selector)
                if btn.is_displayed() and btn.is_enabled():
                    btn.click()
                    time.sleep(2)
                    clicked = True
                    break
            except Exception:
                continue
        if not clicked:
            break


def open_general_search(driver, url: str) -> None:
    driver.get(url)
    time.sleep(3)
    try_accept_disclaimer(driver)
    for by, value in [
        (By.LINK_TEXT, "Search by Record Information"),
        (By.PARTIAL_LINK_TEXT, "Record Information"),
        (By.LINK_TEXT, "General Search"),
        (By.PARTIAL_LINK_TEXT, "General"),
    ]:
        try:
            el = driver.find_element(by, value)
            if el.is_displayed():
                el.click()
                time.sleep(2)
                break
        except Exception:
            pass


def all_visible_inputs(driver) -> List:
    try:
        return [el for el in driver.find_elements(By.XPATH, "//input[not(@type='hidden')] | //textarea") if el.is_displayed()]
    except Exception:
        return []


def smart_find_date_input(driver, kind: str):
    """Find Accela date fields even when city-specific IDs differ."""
    kind_l = kind.lower()
    if kind_l == "start":
        candidates = [
            (By.ID, "ctl00_PlaceHolderMain_generalSearchForm_txtGSStartDate"),
            (By.NAME, "ctl00$PlaceHolderMain$generalSearchForm$txtGSStartDate"),
            (By.XPATH, "//input[contains(translate(@id,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'txtgsstartdate') or contains(translate(@name,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'txtgsstartdate')]"),
            (By.XPATH, "//input[contains(translate(@id,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'startdate') or contains(translate(@name,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'startdate')]"),
            (By.XPATH, "//*[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'start date')]/following::input[1]"),
        ]
    else:
        candidates = [
            (By.ID, "ctl00_PlaceHolderMain_generalSearchForm_txtGSEndDate"),
            (By.NAME, "ctl00$PlaceHolderMain$generalSearchForm$txtGSEndDate"),
            (By.XPATH, "//input[contains(translate(@id,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'txtgsenddate') or contains(translate(@name,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'txtgsenddate')]"),
            (By.XPATH, "//input[contains(translate(@id,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'enddate') or contains(translate(@name,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'enddate')]"),
            (By.XPATH, "//*[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'end date')]/following::input[1]"),
        ]
    try:
        return find_first(driver, candidates)
    except Exception:
        visible = all_visible_inputs(driver)
        date_like = []
        for el in visible:
            attrs = " ".join([str(el.get_attribute(a) or "") for a in ["id", "name", "title", "placeholder", "aria-label"]]).lower()
            if "date" in attrs or "mm/dd" in attrs:
                date_like.append(el)
        if len(date_like) >= 2:
            return date_like[0 if kind_l == "start" else 1]
        raise


def set_search_dates(driver, start: date, end: date, source_name: str = "source") -> None:
    start_text = start.strftime("%m/%d/%Y")
    end_text = end.strftime("%m/%d/%Y")
    try:
        set_input_value(driver, smart_find_date_input(driver, "start"), start_text)
        set_input_value(driver, smart_find_date_input(driver, "end"), end_text)
    except Exception:
        save_debug(driver, source_name, "date_fields_not_found")
        dump_page_inventory(driver, source_name, "date_fields_not_found")
        raise

def maybe_select_record_type(driver, record_type_contains: Optional[str]) -> None:
    if not record_type_contains:
        return
    for by, selector in [
        (By.XPATH, "//select[contains(@id,'ddlGSPermitType') or contains(@name,'ddlGSPermitType')]") ,
        (By.XPATH, "//select[contains(@id,'RecordType') or contains(@name,'RecordType') or contains(@id,'PermitType')]") ,
    ]:
        try:
            sel = Select(driver.find_element(by, selector))
            for opt in sel.options:
                if record_type_contains.lower() in opt.text.lower():
                    sel.select_by_visible_text(opt.text)
                    time.sleep(1)
                    return
        except Exception:
            continue


def click_search(driver) -> None:
    candidates = [
        (By.ID, "ctl00_PlaceHolderMain_btnNewSearch"),
        (By.NAME, "ctl00$PlaceHolderMain$btnNewSearch"),
        (By.XPATH, "//input[contains(@id,'btnNewSearch') or contains(@name,'btnNewSearch')]") ,
        (By.XPATH, "//input[@type='submit' and (contains(@value,'Search') or contains(@title,'Search'))]"),
        (By.XPATH, "//button[contains(.,'Search')]") ,
    ]
    btn = find_first(driver, candidates)
    driver.execute_script("arguments[0].scrollIntoView({block:'center'});", btn)
    btn.click()
    time.sleep(5)


def save_debug(driver, source_name: str, label: str, include_screenshot: bool = True) -> Path:
    """Save the current browser state so we can diagnose missing results/selectors."""
    DEBUG_DIR.mkdir(parents=True, exist_ok=True)
    safe_label = re.sub(r"[^A-Za-z0-9_.-]+", "_", label).strip("_")[:120] or "page"
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    html_path = DEBUG_DIR / f"{source_name}_{safe_label}_{stamp}.html"
    png_path = DEBUG_DIR / f"{source_name}_{safe_label}_{stamp}.png"
    try:
        html_path.write_text(driver.page_source, encoding="utf-8", errors="ignore")
    except Exception as exc:
        html_path.write_text(f"Could not save page source: {exc}", encoding="utf-8")
    if include_screenshot:
        try:
            driver.save_screenshot(str(png_path))
        except Exception:
            pass
    print(f"  [debug] page source: {html_path}")
    return html_path


def dump_page_inventory(driver, source_name: str, label: str) -> Optional[Path]:
    """Save inputs/selects/buttons/links to identify changed Accela selectors."""
    try:
        soup = BeautifulSoup(driver.page_source, "html.parser")
        lines = [f"URL: {driver.current_url}", f"TITLE: {driver.title}", "", "--- INPUTS / TEXTAREAS ---"]
        for el in soup.find_all(["input", "textarea"]):
            lines.append(json.dumps({
                "tag": el.name,
                "id": el.get("id"),
                "name": el.get("name"),
                "type": el.get("type"),
                "value": el.get("value"),
                "placeholder": el.get("placeholder"),
                "title": el.get("title"),
                "class": el.get("class"),
            }, default=str))
        lines.append("\n--- SELECTS ---")
        for el in soup.find_all("select"):
            options = [clean_text(o.get_text(" ", strip=True), 80) for o in el.find_all("option")[:50]]
            lines.append(json.dumps({"id": el.get("id"), "name": el.get("name"), "class": el.get("class"), "options_first_50": options}, default=str))
        lines.append("\n--- BUTTONS / SEARCH / NEXT LINKS ---")
        for el in soup.find_all(["button", "input", "a"]):
            text = clean_text(el.get_text(" ", strip=True) or el.get("value") or el.get("title"), 120)
            if not text:
                continue
            if any(k in text.lower() for k in ["search", "next", "submit", "clear", "continue", "accept", "record"]):
                lines.append(json.dumps({"tag": el.name, "text": text, "id": el.get("id"), "name": el.get("name"), "href": el.get("href"), "class": el.get("class")}, default=str))
        DEBUG_DIR.mkdir(parents=True, exist_ok=True)
        stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        path = DEBUG_DIR / f"{source_name}_{label}_inventory_{stamp}.txt"
        path.write_text("\n".join(lines), encoding="utf-8", errors="ignore")
        print(f"  [debug] inventory: {path}")
        return path
    except Exception as exc:
        print(f"  [warn] could not dump page inventory: {exc}")
        return None

def extract_text_map(html: str) -> Dict[str, str]:
    soup = BeautifulSoup(html, "html.parser")
    text_map: Dict[str, str] = {}
    full_text = soup.get_text("\n", strip=True)
    patterns = {
        "record_number": r"(?:Record|Permit) Number\s*:?\s*([A-Z0-9\-.]+)",
        "record_type": r"Record Type\s*:?\s*(.+)",
        "status": r"Status\s*:?\s*(.+)",
        "issue_date": r"(?:Issue|Issued) Date\s*:?\s*(\d{1,2}/\d{1,2}/\d{2,4})",
        "opened_date": r"Opened Date\s*:?\s*(\d{1,2}/\d{1,2}/\d{2,4})",
        "address": r"Address\s*:?\s*(.+)",
        "owner": r"Owner\s*:?\s*(.+)",
        "contractor": r"(?:Licensed Professional|Contractor)\s*:?\s*(.+)",
        "project_description": r"Project Description\s*:?\s*(.+?)(?:\s+Owner:|\s+More Details|\s+Related Contacts|\s+Valuation|\s+Application Information|$)",
        "description": r"(?:Scope of Work|Project Name)\s*:?\s*(.+)",
    }
    for key, pattern in patterns.items():
        m = re.search(pattern, full_text, re.I)
        if m:
            text_map[key] = clean_text(m.group(1), 500) or ""
    text_map["full_text"] = clean_text(full_text, 5000) or ""
    return text_map


def extract_result_links(driver) -> List[Tuple[str, str, Dict[str, str]]]:
    soup = BeautifulSoup(driver.page_source, "html.parser")
    links: List[Tuple[str, str, Dict[str, str]]] = []
    for a in soup.find_all("a", href=True):
        href = a.get("href", "")
        text = clean_text(a.get_text(" ", strip=True)) or ""
        if "CapDetail.aspx" not in href and "CapHome.aspx" not in href:
            continue
        if not is_valid_permit_number(text):
            continue
        row = a.find_parent("tr")
        row_data: Dict[str, str] = {}
        if row:
            cells = [clean_text(td.get_text(" ", strip=True)) for td in row.find_all(["td", "th"])]
            row_data = {f"cell_{i}": c for i, c in enumerate(cells) if c}
        links.append((text, urljoin(driver.current_url, href), row_data))
    seen = set()
    unique = []
    for text, url, row_data in links:
        key = (text, url)
        if key not in seen:
            seen.add(key)
            unique.append((text, url, row_data))
    return unique


def next_results_page(driver) -> bool:
    for by, selector in [
        (By.LINK_TEXT, "Next >"),
        (By.LINK_TEXT, "Next"),
        (By.XPATH, "//a[contains(.,'Next') and not(contains(@class,'disabled'))]"),
    ]:
        try:
            el = driver.find_element(by, selector)
            if el.is_displayed() and el.is_enabled():
                el.click()
                time.sleep(4)
                return True
        except Exception:
            continue
    return False


def guess_from_row(record_number: str, row_data: Dict[str, str]) -> Dict[str, Optional[str]]:
    cells = list(row_data.values())
    joined = " | ".join(cells)
    out: Dict[str, Optional[str]] = {
        "permit_type": None, "project_description": None, "address_1": None,
        "owner_name": None, "status": None, "issued_date": None,
    }
    for c in cells:
        if not out["issued_date"] and DATE_RE.search(c):
            out["issued_date"] = DATE_RE.search(c).group(0)
        if not out["status"] and re.search(r"\b(SUBMITTED|RESPONSE RECEIVED|ISSUED|FINAL|EXPIRED|CLOSED|OPEN|ACTIVE|VOID)\b", c, re.I):
            out["status"] = c
        if not out["address_1"]:
            out["address_1"] = extract_address_from_text(c)
        if re.search(r"\b(ROOF|ELECT|PLUMB|MECH|HVAC|BUILD|POOL|FENCE|WINDOW|DOOR|SOLAR|DEMO|WATER HEATER)\b", c, re.I):
            if not out["permit_type"]:
                out["permit_type"] = clean_text(c, 120)
            if not out["project_description"]:
                out["project_description"] = clean_text(c, 500)
    if not out["project_description"]:
        out["project_description"] = clean_text(joined, 500)
    return out



def pick_accela_description(payload: Dict[str, str], row_guess: Dict[str, Optional[str]]) -> Optional[str]:
    """
    Accela detail pages include a UI collection button labeled "Add" near the word
    Description. That can pollute generic text extraction. For Weston results, the
    actual work description is reliably in the search-result row:
      cell_8 = detailed scope / project description
      cell_4 = subtype / trade-specific work type
      cell_3 = record type
    Fallbacks parse Project Description from full_text only when needed.
    """
    for key in ("cell_8", "cell_4", "cell_3"):
        value = clean_text(payload.get(key), 500)
        if value and value.lower() != "add" and not is_junk_text(value):
            return value

    full_text = payload.get("full_text") or ""
    m = re.search(
        r"Project Description:\s*(.+?)(?:\s+Owner:|\s+More Details|\s+Related Contacts|\s+Valuation|\s+Application Information|$)",
        full_text,
        re.I | re.S,
    )
    if m:
        value = clean_text(m.group(1), 500)
        if value and value.lower() != "add" and not is_junk_text(value):
            return value

    value = clean_text(payload.get("project_description") or payload.get("description"), 500)
    if value and value.lower() != "add" and not is_junk_text(value):
        return value

    return row_guess.get("project_description")


def pick_accela_permit_type(payload: Dict[str, str], row_guess: Dict[str, Optional[str]]) -> Optional[str]:
    for key in ("cell_3", "cell_4", "record_type"):
        value = clean_text(payload.get(key), 120)
        if value and value.lower() != "add" and not is_junk_text(value):
            return value
    return row_guess.get("permit_type")

def infer_trade(text: str) -> Optional[str]:
    t = (text or "").lower()
    mapping = [
        ("roofing", ["roof", "reroof"]),
        ("electrical", ["elect", "service change", "panel"]),
        ("plumbing", ["plumb", "sewer", "water heater"]),
        ("hvac", ["hvac", "mechanical", "air conditioning", "a/c", "ac change"]),
        ("pool", ["pool", "spa"]),
        ("solar", ["solar", "photovoltaic", "pv"]),
        ("windows_doors", ["window", "door", "opening"]),
        ("fence", ["fence"]),
        ("general", ["building", "alteration", "renovation", "remodel", "addition", "demo"]),
    ]
    for trade, keys in mapping:
        if any(k in t for k in keys):
            return trade
    return None


def scrape_source(source: Dict, start: date, end: date, visible: bool, limit: int, pages: int, debug_pages: bool = False) -> List[PermitRecord]:
    source_name = source["name"]
    jurisdiction = source.get("jurisdiction") or "Broward"
    driver = make_driver(visible=visible)
    records: List[PermitRecord] = []
    try:
        print(f"[source] {source_name}: {start} to {end}")
        open_general_search(driver, source["base_url"])
        if debug_pages:
            save_debug(driver, source_name, "01_search_form_loaded")
            dump_page_inventory(driver, source_name, "01_search_form_loaded")
        set_search_dates(driver, start, end, source_name=source_name)
        maybe_select_record_type(driver, source.get("record_type_contains"))
        if debug_pages:
            save_debug(driver, source_name, "02_search_form_filled")
        click_search(driver)
        if debug_pages:
            save_debug(driver, source_name, "03_after_search_click")
            dump_page_inventory(driver, source_name, "03_after_search_click")
        for page_num in range(1, pages + 1):
            if debug_pages:
                save_debug(driver, source_name, f"results_page_{page_num:03d}")
            links = extract_result_links(driver)
            print(f"  page {page_num}: {len(links)} result link(s)")
            if not links:
                save_debug(driver, source_name, "no_results")
                break
            for record_number, detail_url, row_data in links:
                if limit and len(records) >= limit:
                    return records
                row_guess = guess_from_row(record_number, row_data)
                detail_payload = dict(row_data)
                detail_payload["detail_url"] = detail_url
                try:
                    driver.get(detail_url)
                    time.sleep(3)
                    if debug_pages and len(records) < 8:
                        save_debug(driver, source_name, f"detail_{record_number}", include_screenshot=False)
                    detail_payload.update(extract_text_map(driver.page_source))
                except Exception as exc:
                    detail_payload["detail_error"] = str(exc)
                def first_value(*keys):
                    for key in keys:
                        for actual, val in detail_payload.items():
                            if key.lower() in actual.lower() and val:
                                return clean_text(str(val))
                    return None
                rec = PermitRecord(
                    source_name=source_name,
                    jurisdiction=jurisdiction,
                    permit_number=record_number,
                    permit_type=pick_accela_permit_type(detail_payload, row_guess),
                    project_description=pick_accela_description(detail_payload, row_guess),
                    address_1=first_value("address", "Address") or row_guess.get("address_1"),
                    owner_name=first_value("owner", "Owner", "Applicant"),
                    business_name=first_value("contractor", "Licensed Professional", "Contractor", "Business"),
                    issued_date=parse_date(first_value("issue_date", "Issue Date", "Issued Date", "opened_date") or row_guess.get("issued_date")),
                    status=first_value("status", "Status") or row_guess.get("status"),
                    raw_url=detail_url,
                    raw_payload=detail_payload,
                )
                rec = normalize_record(rec)
                if rec:
                    records.append(rec)
                try:
                    driver.back(); time.sleep(2)
                except Exception:
                    pass
            if limit and len(records) >= limit:
                break
            if not next_results_page(driver):
                break
    except Exception as exc:
        print(f"  [error] {source_name}: {exc}")
        try:
            save_debug(driver, source_name, "error")
        except Exception:
            pass
    finally:
        driver.quit()
    return records


def get_county_id(cur) -> int:
    cur.execute("SELECT id FROM counties WHERE county_name = %s", (COUNTY_NAME,))
    row = cur.fetchone()
    if row:
        return row[0]
    cur.execute("INSERT INTO counties (county_name, state, active) VALUES (%s, %s, true) RETURNING id", (COUNTY_NAME, STATE))
    return cur.fetchone()[0]


def save_raw_snapshot(records: List[PermitRecord]) -> Optional[Path]:
    if not records:
        return None
    RAW_DIR.mkdir(parents=True, exist_ok=True)
    path = RAW_DIR / f"broward_accela_permits_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
    payload = [r.__dict__ | {"issued_date": r.issued_date.isoformat() if r.issued_date else None} for r in records]
    path.write_text(json.dumps(payload, indent=2, default=str), encoding="utf-8")
    return path


def import_records(records: List[PermitRecord]) -> Dict[str, int]:
    stats = {"raw_inserted": 0, "raw_updated": 0, "normalized_inserted": 0, "normalized_updated": 0, "skipped_no_permit": 0}
    if not records:
        return stats
    conn = get_connection()
    try:
        with conn:
            with conn.cursor() as cur:
                county_id = get_county_id(cur)
                for rec in records:
                    rec = normalize_record(rec)
                    if not rec or not rec.permit_number:
                        stats["skipped_no_permit"] += 1
                        continue
                    source_record_id = f"{rec.source_name}:{rec.permit_number}"
                    raw_payload = json.dumps(rec.raw_payload or {}, default=str)
                    cur.execute(
                        """
                        INSERT INTO raw_permits (county_id, source_file, source_record_id, raw_payload, issued_date)
                        VALUES (%s, %s, %s, %s::jsonb, %s)
                        ON CONFLICT (county_id, source_record_id)
                        DO UPDATE SET raw_payload = EXCLUDED.raw_payload, issued_date = EXCLUDED.issued_date, scraped_at = NOW()
                        RETURNING id, (xmax = 0) AS is_insert
                        """,
                        (county_id, rec.source_name, source_record_id, raw_payload, rec.issued_date),
                    )
                    raw_id, is_insert = cur.fetchone()
                    stats["raw_inserted" if is_insert else "raw_updated"] += 1
                    normalized_owner = normalize_name(rec.owner_name or "") or None
                    normalized_addr = normalize_address(rec.address_1 or "") or None
                    business_name = clean_text(rec.business_name, 180)
                    normalized_hash = make_hash(rec.permit_number, normalized_owner, normalized_addr, rec.permit_type, rec.issued_date)
                    cur.execute(
                        """
                        INSERT INTO normalized_permits (
                            county_id, raw_permit_id, owner_name, business_name, address_1,
                            city, state, permit_number, permit_type, project_description,
                            issued_date, trade, normalized_hash
                        )
                        VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
                        ON CONFLICT (county_id, permit_number)
                        DO UPDATE SET
                            raw_permit_id = EXCLUDED.raw_permit_id,
                            owner_name = EXCLUDED.owner_name,
                            business_name = EXCLUDED.business_name,
                            address_1 = EXCLUDED.address_1,
                            city = EXCLUDED.city,
                            state = EXCLUDED.state,
                            permit_type = EXCLUDED.permit_type,
                            project_description = EXCLUDED.project_description,
                            issued_date = EXCLUDED.issued_date,
                            trade = EXCLUDED.trade,
                            normalized_hash = EXCLUDED.normalized_hash
                        RETURNING id, (xmax = 0) AS is_insert
                        """,
                        (
                            county_id, raw_id, normalized_owner, business_name, normalized_addr,
                            rec.jurisdiction, STATE, rec.permit_number, clean_text(rec.permit_type, 100),
                            clean_text(rec.project_description, 500), rec.issued_date, rec.trade, normalized_hash,
                        ),
                    )
                    _, norm_insert = cur.fetchone()
                    stats["normalized_inserted" if norm_insert else "normalized_updated"] += 1
    finally:
        conn.close()
    return stats


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--days-back", type=int, default=7)
    parser.add_argument("--start", help="Explicit start date YYYY-MM-DD")
    parser.add_argument("--end", help="Explicit end date YYYY-MM-DD")
    parser.add_argument("--visible", action="store_true")
    parser.add_argument("--limit", type=int, default=100, help="Max records per source; 0 = unlimited")
    parser.add_argument("--pages", type=int, default=3)
    parser.add_argument("--source", help="Only run one source name from config")
    parser.add_argument("--all-broward", action="store_true", help="Run every configured Broward source. Same as omitting --source; included for readability.")
    parser.add_argument("--debug-pages", action="store_true", help="Save page source, screenshots, and selector inventories to data/debug/broward_permits.")
    args = parser.parse_args()
    end = datetime.strptime(args.end, "%Y-%m-%d").date() if args.end else date.today()
    start = datetime.strptime(args.start, "%Y-%m-%d").date() if args.start else end - timedelta(days=args.days_back)
    sources = load_sources()
    if args.source:
        sources = [s for s in sources if s.get("name") == args.source]
    if not sources:
        raise RuntimeError("No Broward permit sources configured")
    print(f"Running {len(sources)} Broward source(s): " + ", ".join(s.get("name", "unknown") for s in sources))
    all_records: List[PermitRecord] = []
    for source in sources:
        recs = scrape_source(source, start, end, visible=args.visible, limit=args.limit, pages=args.pages, debug_pages=args.debug_pages)
        print(f"  {source['name']} records scraped: {len(recs)}")
        all_records.extend(recs)
    deduped: List[PermitRecord] = []
    seen = set()
    for rec in all_records:
        key = (rec.source_name, rec.permit_number)
        if key not in seen:
            seen.add(key)
            deduped.append(rec)
    snapshot = save_raw_snapshot(deduped)
    if snapshot:
        print(f"Raw Broward permit snapshot saved: {snapshot}")
    stats = import_records(deduped)
    print("\n--- Broward permit scrape/import summary ---")
    print(f"  sources_run          : {len(sources)}")
    print(f"  records_scraped      : {len(deduped)}")
    for k, v in stats.items():
        print(f"  {k:<20}: {v}")

if __name__ == "__main__":
    main()
