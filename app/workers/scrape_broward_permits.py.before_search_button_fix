def smart_find_date_input(driver: webdriver.Chrome, kind: str):
    """Find Accela date inputs without relying on one exact ID."""
    kind_lower = kind.lower()
    if kind_lower.startswith("start"):
        patterns = [
            "startdate", "start_date", "datefrom", "date_from", "fromdate", "from_date",
            "ctl00_PlaceHolderMain_generalSearchForm_txtGSStartDate", "GSStartDate",
        ]
        label_words = ["start date", "from"]
    else:
        patterns = [
            "enddate", "end_date", "dateto", "date_to", "todate", "to_date",
            "ctl00_PlaceHolderMain_generalSearchForm_txtGSEndDate", "GSEndDate",
        ]
        label_words = ["end date", "to"]

    inputs = driver.find_elements(By.XPATH, "//input[not(@type='hidden') and not(@type='submit') and not(@type='button')]")
    candidates = []
    for el in inputs:
        attrs = " ".join(
            clean_text(el.get_attribute(a)).lower()
            for a in ("id", "name", "placeholder", "title", "aria-label", "class", "value")
        )
        if any(p.lower() in attrs for p in patterns):
            candidates.append(el)

    if candidates:
        return candidates[0]

    # Fallback: locate by nearby label text.
    for word in label_words:
        xp = f"//*[contains(translate(normalize-space(.),'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'{word}')]/following::input[not(@type='hidden')][1]"
        try:
            return driver.find_element(By.XPATH, xp)
        except NoSuchElementException:
            pass

    # Final fallback: visible text fields that currently contain a date or look like date fields.
    date_like = []
    for el in inputs:
        val = clean_text(el.get_attribute("value"))
        size = clean_text(el.get_attribute("size"))
        max_len = clean_text(el.get_attribute("maxlength"))
        if DATE_RE.search(val) or size in {"10", "12"} or max_len in {"10", "12"}:
            date_like.append(el)
    if len(date_like) >= 2:
        return date_like[0] if kind_lower.startswith("start") else date_like[1]

    raise NoSuchElementException(f"Could not find {kind} date input")


def set_input_value(driver: webdriver.Chrome, element, value: str) -> None:
    """Accela date fields may be masked. Verify final value sticks."""
    driver.execute_script("arguments[0].scrollIntoView({block:'center'});", element)
    time.sleep(0.2)
    try:
        driver.execute_script("arguments[0].removeAttribute('readonly'); arguments[0].removeAttribute('disabled');", element)
    except Exception:
        pass

    for _ in range(3):
        try:
            element.click()
            time.sleep(0.1)
            element.send_keys(Keys.CONTROL, "a")
            element.send_keys(Keys.BACKSPACE)
            element.send_keys(value)
            element.send_keys(Keys.TAB)
            time.sleep(0.4)
            current = clean_text(element.get_attribute("value"))
            if current == value:
                return
        except Exception:
            pass

    driver.execute_script(
        """
        const el = arguments[0];
        const val = arguments[1];
        el.focus();
        el.value = val;
        el.setAttribute('value', val);
        ['keydown','keypress','keyup','input','change','blur'].forEach(name => {
            el.dispatchEvent(new Event(name, { bubbles: true }));
        });
        """,
        element,
        value,
    )
    time.sleep(0.5)
    current = clean_text(element.get_attribute("value"))
    if current != value:
        raise RuntimeError(f"Could not set input value. Wanted {value}, got {current}")


def set_search_dates(driver: webdriver.Chrome, start: date, end: date, source_name: str = "source") -> None:
    start_text = start.strftime("%m/%d/%Y")
    end_text = end.strftime("%m/%d/%Y")
    try:
        start_el = smart_find_date_input(driver, "start")
        end_el = smart_find_date_input(driver, "end")
        set_input_value(driver, start_el, start_text)
        set_input_value(driver, end_el, end_text)
        actual_start = clean_text(start_el.get_attribute("value"))
        actual_end = clean_text(end_el.get_attribute("value"))
        print(f"  [dates] requested {start_text} to {end_text}")
        print(f"  [dates] actual    {actual_start} to {actual_end}")
        if actual_start != start_text or actual_end != end_text:
            save_debug(driver, source_name, "date_values_wrong_after_fill")
            dump_page_inventory(driver, source_name, "date_values_wrong_after_fill")
            raise RuntimeError(f"Date fields did not stick. Expected {start_text}-{end_text}, got {actual_start}-{actual_end}")
    except Exception:
        save_debug(driver, source_name, "date_fields_not_found")
        dump_page_inventory(driver, source_name, "date_fields_not_found")
        raise


def maybe_select_record_type(driver: webdriver.Chrome, contains_text: Optional[str]) -> None:
    if not contains_text:
        return
    target = contains_text.lower()
    # Select dropdowns first.
    for sel in driver.find_elements(By.TAG_NAME, "select"):
        try:
            options = sel.find_elements(By.TAG_NAME, "option")
            for opt in options:
                if target in clean_text(opt.text).lower():
                    opt.click()
                    time.sleep(0.5)
                    print(f"  [filter] selected record type: {clean_text(opt.text)}")
                    return
        except Exception:
            continue
    # Fallback for Accela custom dropdown/input.
    try:
        candidates = driver.find_elements(By.XPATH, "//input|//textarea")
        for el in candidates:
            attrs = " ".join(clean_text(el.get_attribute(a)).lower() for a in ("id", "name", "placeholder", "title", "aria-label"))
            if "record" in attrs and "type" in attrs:
                set_input_value(driver, el, contains_text)
                print(f"  [filter] typed record type: {contains_text}")
                return
    except Exception:
        pass


